<?xml version="1.0" encoding="UTF-8" ?>
<?xaml-comp compile="true" ?>
<ResourceDictionary 
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <Style TargetType="ActivityIndicator">
        <Setter Property="Color" Value="#CC0000" />
    </Style>

    <Style TargetType="IndicatorView">
        <Setter Property="IndicatorColor" Value="#444444"/>
        <Setter Property="SelectedIndicatorColor" Value="#CC0000"/>
    </Style>

    <Style TargetType="Border">
        <Setter Property="Stroke" Value="#222222" />
        <Setter Property="StrokeShape" Value="Rectangle"/>
        <Setter Property="StrokeThickness" Value="1"/>
    </Style>

    <Style TargetType="BoxView">
        <Setter Property="BackgroundColor" Value="#141414" />
    </Style>

    <Style TargetType="Button">
        <Setter Property="TextColor" Value="#FFFFFF" />
        <Setter Property="BackgroundColor" Value="#CC0000" />
        <Setter Property="FontFamily" Value="OpenSansRegular"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="BorderWidth" Value="0"/>
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="Padding" Value="14,10"/>
        <Setter Property="MinimumHeightRequest" Value="44"/>
        <Setter Property="MinimumWidthRequest" Value="44"/>
        <Setter Property="VisualStateManager.VisualStateGroups">
            <VisualStateGroupList>
                <VisualStateGroup x:Name="CommonStates">
                    <VisualState x:Name="Normal" />
                    <VisualState x:Name="Disabled">
                        <VisualState.Setters>
                            <Setter Property="TextColor" Value="#555555" />
                            <Setter Property="BackgroundColor" Value="#1A1A1A" />
                        </VisualState.Setters>
                    </VisualState>
                    <VisualState x:Name="PointerOver" />
                </VisualStateGroup>
            </VisualStateGroupList>
        </Setter>
    </Style>

    <Style TargetType="CheckBox">
        <Setter Property="Color" Value="#CC0000" />
        <Setter Property="MinimumHeightRequest" Value="44"/>
        <Setter Property="MinimumWidthRequest" Value="44"/>
        <Setter Property="VisualStateManager.VisualStateGroups">
            <VisualStateGroupList>
                <VisualStateGroup x:Name="CommonStates">
                    <VisualState x:Name="Normal" />
                    <VisualState x:Name="Disabled">
                        <VisualState.Setters>
                            <Setter Property="Color" Value="#444444" />
                        </VisualState.Setters>
                    </VisualState>
                </VisualStateGroup>
            </VisualStateGroupList>
        </Setter>
    </Style>

    <Style TargetType="DatePicker">
        <Setter Property="TextColor" Value="#FFFFFF" />
        <Setter Property="BackgroundColor" Value="Transparent" />
        <Setter Property="FontFamily" Value="OpenSansRegular"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="MinimumHeightRequest" Value="44"/>
        <Setter Property="MinimumWidthRequest" Value="44"/>
    </Style>

    <Style TargetType="Editor">
        <Setter Property="TextColor" Value="#FFFFFF" />
        <Setter Property="BackgroundColor" Value="Transparent" />
        <Setter Property="FontFamily" Value="OpenSansRegular"/>
        <Setter Property="FontSize" Value="14" />
        <Setter Property="PlaceholderColor" Value="#555555" />
        <Setter Property="MinimumHeightRequest" Value="44"/>
        <Setter Property="MinimumWidthRequest" Value="44"/>
    </Style>

    <Style TargetType="Entry">
        <Setter Property="TextColor" Value="#FFFFFF" />
        <Setter Property="BackgroundColor" Value="Transparent" />
        <Setter Property="FontFamily" Value="OpenSansRegular"/>
        <Setter Property="FontSize" Value="14" />
        <Setter Property="PlaceholderColor" Value="#555555" />
        <Setter Property="MinimumHeightRequest" Value="44"/>
        <Setter Property="MinimumWidthRequest" Value="44"/>
        <Setter Property="VisualStateManager.VisualStateGroups">
            <VisualStateGroupList>
                <VisualStateGroup x:Name="CommonStates">
                    <VisualState x:Name="Normal" />
                    <VisualState x:Name="Disabled">
                        <VisualState.Setters>
                            <Setter Property="TextColor" Value="#444444" />
                        </VisualState.Setters>
                    </VisualState>
                </VisualStateGroup>
            </VisualStateGroupList>
        </Setter>
    </Style>

    <Style TargetType="ImageButton">
        <Setter Property="Opacity" Value="1" />
        <Setter Property="BorderColor" Value="Transparent"/>
        <Setter Property="BorderWidth" Value="0"/>
        <Setter Property="CornerRadius" Value="0"/>
        <Setter Property="MinimumHeightRequest" Value="44"/>
        <Setter Property="MinimumWidthRequest" Value="44"/>
    </Style>

    <Style TargetType="Label">
        <Setter Property="TextColor" Value="#FFFFFF" />
        <Setter Property="BackgroundColor" Value="Transparent" />
        <Setter Property="FontFamily" Value="OpenSansRegular" />
        <Setter Property="FontSize" Value="14" />
    </Style>

    <Style TargetType="Label" x:Key="Headline">
        <Setter Property="TextColor" Value="#FFFFFF" />
        <Setter Property="FontSize" Value="32" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="HorizontalOptions" Value="Center" />
        <Setter Property="HorizontalTextAlignment" Value="Center" />
    </Style>

    <Style TargetType="Label" x:Key="SubHeadline">
        <Setter Property="TextColor" Value="#888888" />
        <Setter Property="FontSize" Value="18" />
        <Setter Property="HorizontalOptions" Value="Center" />
        <Setter Property="HorizontalTextAlignment" Value="Center" />
    </Style>

    <Style TargetType="ListView">
        <Setter Property="SeparatorColor" Value="#222222" />
        <Setter Property="BackgroundColor" Value="#0A0A0A" />
        <Setter Property="RefreshControlColor" Value="#CC0000" />
    </Style>

    <Style TargetType="Picker">
        <Setter Property="TextColor" Value="#FFFFFF" />
        <Setter Property="TitleColor" Value="#888888" />
        <Setter Property="BackgroundColor" Value="Transparent" />
        <Setter Property="FontFamily" Value="OpenSansRegular"/>
        <Setter Property="FontSize" Value="14" />
        <Setter Property="MinimumHeightRequest" Value="44"/>
        <Setter Property="MinimumWidthRequest" Value="44"/>
    </Style>

    <Style TargetType="ProgressBar">
        <Setter Property="ProgressColor" Value="#CC0000" />
        <Setter Property="BackgroundColor" Value="#1A1A1A" />
    </Style>

    <Style TargetType="RadioButton">
        <Setter Property="BackgroundColor" Value="Transparent"/>
        <Setter Property="TextColor" Value="#FFFFFF" />
        <Setter Property="FontFamily" Value="OpenSansRegular"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="MinimumHeightRequest" Value="44"/>
        <Setter Property="MinimumWidthRequest" Value="44"/>
    </Style>

    <Style TargetType="RefreshView">
        <Setter Property="RefreshColor" Value="#CC0000" />
    </Style>

    <Style TargetType="SearchBar">
        <Setter Property="TextColor" Value="#FFFFFF" />
        <Setter Property="PlaceholderColor" Value="#555555" />
        <Setter Property="CancelButtonColor" Value="#888888" />
        <Setter Property="BackgroundColor" Value="#141414" />
        <Setter Property="FontFamily" Value="OpenSansRegular" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="MinimumHeightRequest" Value="44"/>
        <Setter Property="MinimumWidthRequest" Value="44"/>
    </Style>

    <Style TargetType="SearchHandler">
        <Setter Property="TextColor" Value="#FFFFFF" />
        <Setter Property="PlaceholderColor" Value="#555555" />
        <Setter Property="BackgroundColor" Value="#0A0A0A" />
        <Setter Property="FontFamily" Value="OpenSansRegular" />
        <Setter Property="FontSize" Value="14" />
    </Style>

    <Style TargetType="Shadow">
        <Setter Property="Radius" Value="15" />
        <Setter Property="Opacity" Value="0.5" />
        <Setter Property="Brush" Value="#000000" />
        <Setter Property="Offset" Value="5,5" />
    </Style>

    <Style TargetType="Slider">
        <Setter Property="MinimumTrackColor" Value="#CC0000" />
        <Setter Property="MaximumTrackColor" Value="#222222" />
        <Setter Property="ThumbColor" Value="#FF0033" />
    </Style>

    <Style TargetType="SwipeItem">
        <Setter Property="BackgroundColor" Value="#0A0A0A" />
    </Style>

    <Style TargetType="Switch">
        <Setter Property="OnColor" Value="#CC0000" />
        <Setter Property="ThumbColor" Value="#FFFFFF" />
        <Setter Property="VisualStateManager.VisualStateGroups">
            <VisualStateGroupList>
                <VisualStateGroup x:Name="CommonStates">
                    <VisualState x:Name="Normal" />
                    <VisualState x:Name="Disabled">
                        <VisualState.Setters>
                            <Setter Property="OnColor" Value="#444444" />
                            <Setter Property="ThumbColor" Value="#555555" />
                        </VisualState.Setters>
                    </VisualState>
                </VisualStateGroup>
            </VisualStateGroupList>
        </Setter>
    </Style>

    <Style TargetType="TimePicker">
        <Setter Property="TextColor" Value="#FFFFFF" />
        <Setter Property="BackgroundColor" Value="Transparent"/>
        <Setter Property="FontFamily" Value="OpenSansRegular"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="MinimumHeightRequest" Value="44"/>
        <Setter Property="MinimumWidthRequest" Value="44"/>
    </Style>

    <Style TargetType="Page" ApplyToDerivedTypes="True">
        <Setter Property="Padding" Value="0"/>
        <Setter Property="BackgroundColor" Value="#0A0A0A" />
    </Style>

    <Style TargetType="Shell" ApplyToDerivedTypes="True">
        <Setter Property="Shell.BackgroundColor" Value="#0A0A0A" />
        <Setter Property="Shell.ForegroundColor" Value="#CC0000" />
        <Setter Property="Shell.TitleColor" Value="#FFFFFF" />
        <Setter Property="Shell.DisabledColor" Value="#444444" />
        <Setter Property="Shell.UnselectedColor" Value="#888888" />
        <Setter Property="Shell.NavBarHasShadow" Value="False" />
        <Setter Property="Shell.TabBarBackgroundColor" Value="#0A0A0A" />
        <Setter Property="Shell.TabBarForegroundColor" Value="#CC0000" />
        <Setter Property="Shell.TabBarTitleColor" Value="#CC0000" />
        <Setter Property="Shell.TabBarUnselectedColor" Value="#888888" />
    </Style>

    <Style TargetType="NavigationPage">
        <Setter Property="BarBackgroundColor" Value="#0A0A0A" />
        <Setter Property="BarTextColor" Value="#FFFFFF" />
        <Setter Property="IconColor" Value="#CC0000" />
    </Style>

    <Style TargetType="TabbedPage">
        <Setter Property="BarBackgroundColor" Value="#0A0A0A" />
        <Setter Property="BarTextColor" Value="#CC0000" />
        <Setter Property="UnselectedTabColor" Value="#888888" />
        <Setter Property="SelectedTabColor" Value="#CC0000" />
    </Style>

    <!-- Kraken Custom Styles -->
    <Style x:Key="KrakenTitle" TargetType="Label">
        <Setter Property="TextColor" Value="#CC0000" />
        <Setter Property="FontSize" Value="28" />
        <Setter Property="FontAttributes" Value="Bold" />
    </Style>

    <Style x:Key="KrakenSubtitle" TargetType="Label">
        <Setter Property="TextColor" Value="#888888" />
        <Setter Property="FontSize" Value="14" />
    </Style>

    <Style x:Key="KrakenCard" TargetType="Border">
        <Setter Property="BackgroundColor" Value="#141414" />
        <Setter Property="Stroke" Value="#222222" />
        <Setter Property="StrokeThickness" Value="1" />
        <Setter Property="StrokeShape" Value="RoundRectangle 12" />
        <Setter Property="Padding" Value="16" />
    </Style>

    <Style x:Key="KrakenCardRed" TargetType="Border">
        <Setter Property="BackgroundColor" Value="#1A0505" />
        <Setter Property="Stroke" Value="#440B0B" />
        <Setter Property="StrokeThickness" Value="1" />
        <Setter Property="StrokeShape" Value="RoundRectangle 10" />
        <Setter Property="Padding" Value="14" />
    </Style>

    <Style x:Key="KrakenPrimaryButton" TargetType="Button">
        <Setter Property="BackgroundColor" Value="#CC0000" />
        <Setter Property="TextColor" Value="#FFFFFF" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="FontSize" Value="16" />
        <Setter Property="CornerRadius" Value="10" />
        <Setter Property="Padding" Value="24,14" />
        <Setter Property="BorderColor" Value="#FF0033" />
        <Setter Property="BorderWidth" Value="1" />
    </Style>

    <Style x:Key="KrakenSecondaryButton" TargetType="Button">
        <Setter Property="BackgroundColor" Value="#1A1A1A" />
        <Setter Property="TextColor" Value="#CCCCCC" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Padding" Value="20,12" />
        <Setter Property="BorderColor" Value="#222222" />
        <Setter Property="BorderWidth" Value="1" />
    </Style>

    <Style x:Key="KrakenStatLabel" TargetType="Label">
        <Setter Property="TextColor" Value="#FF3344" />
        <Setter Property="FontSize" Value="11" />
        <Setter Property="FontAttributes" Value="Bold" />
    </Style>

    <Style x:Key="KrakenStatValue" TargetType="Label">
        <Setter Property="TextColor" Value="#FFFFFF" />
        <Setter Property="FontSize" Value="15" />
        <Setter Property="FontAttributes" Value="Bold" />
    </Style>

    <Style x:Key="KrakenSectionTitle" TargetType="Label">
        <Setter Property="TextColor" Value="#FFFFFF" />
        <Setter Property="FontSize" Value="22" />
        <Setter Property="FontAttributes" Value="Bold" />
    </Style>

    <Style x:Key="KrakenSectionSubtitle" TargetType="Label">
        <Setter Property="TextColor" Value="#888888" />
        <Setter Property="FontSize" Value="13" />
    </Style>

    <Style x:Key="KrakenEntry" TargetType="Entry">
        <Setter Property="TextColor" Value="#FFFFFF" />
        <Setter Property="PlaceholderColor" Value="#555555" />
        <Setter Property="BackgroundColor" Value="#111111" />
        <Setter Property="FontSize" Value="14" />
    </Style>

</ResourceDictionary>
