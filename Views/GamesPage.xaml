<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:KrakenMobile.ViewModels"
             x:Class="KrakenMobile.Views.GamesPage"
             BackgroundColor="#0A0A0A"
             Title="Games">

    <Grid RowDefinitions="Auto,*">

        <!-- Search Bar -->
        <Border Grid.Row="0"
                BackgroundColor="#141414"
                Stroke="#222222"
                StrokeThickness="0,0,0,1"
                Padding="16,12">

            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">

                <SearchBar Grid.Column="0"
                           Placeholder="Search games..."
                           PlaceholderColor="#555555"
                           TextColor="#FFFFFF"
                           BackgroundColor="#0D0D0D"
                           FontSize="14"
                           CancelButtonColor="#888888"
                           Text="{Binding SearchText}"
                           SearchCommand="{Binding SearchGamesCommand}" />

                <Button Grid.Column="1"
                        Text="&#x1F504;"
                        BackgroundColor="#CC0000"
                        TextColor="#FFFFFF"
                        FontSize="18"
                        CornerRadius="8"
                        WidthRequest="44"
                        HeightRequest="44"
                        Padding="0"
                        Command="{Binding LoadGamesCommand}"
                        VerticalOptions="Center" />
            </Grid>
        </Border>

        <!-- Loading Indicator -->
        <ActivityIndicator Grid.Row="0"
                           IsRunning="{Binding IsLoading}"
                           IsVisible="{Binding IsLoading}"
                           Color="#CC0000"
                           VerticalOptions="Center"
                           HorizontalOptions="Center"
                           Margin="0,50,0,0"
                           HeightRequest="50" />

        <!-- Game Count Label -->
        <Label Grid.Row="0"
               Text="{Binding GameCountText}"
               FontSize="11"
               TextColor="#888888"
               Margin="16,62,0,0"
               IsVisible="{Binding IsInitialized}" />

        <!-- Games Collection -->
        <RefreshView Grid.Row="1"
                     IsRefreshing="{Binding IsLoading}"
                     Command="{Binding LoadGamesCommand}"
                     RefreshColor="#CC0000">

            <CollectionView ItemsSource="{Binding Games}"
                            SelectionMode="Single"
                            SelectionChangedCommand="{Binding SelectGameCommand}"
                            SelectionChangedCommandParameter="{Binding Source={RelativeSource Self}, Path=SelectedItem}">
                <CollectionView.ItemsLayout>
                    <LinearItemsLayout Orientation="Vertical" ItemSpacing="10" />
                </CollectionView.ItemsLayout>
                <CollectionView.Header>
                    <BoxView HeightRequest="1" Color="Transparent" />
                </CollectionView.Header>
                <CollectionView.EmptyViewTemplate>
                    <DataTemplate>
                        <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Padding="32" Spacing="12">
                            <Label Text="No games found"
                                   FontSize="18"
                                   FontAttributes="Bold"
                                   TextColor="#FFFFFF"
                                   HorizontalOptions="Center" />
                            <Label Text="Sign in and load your profile to see games."
                                   FontSize="13"
                                   TextColor="#888888"
                                   HorizontalOptions="Center"
                                   HorizontalTextAlignment="Center" />
                        </VerticalStackLayout>
                    </DataTemplate>
                </CollectionView.EmptyViewTemplate>
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border BackgroundColor="#141414"
                                Stroke="#222222"
                                StrokeThickness="1"
                                StrokeShape="RoundRectangle 10"
                                Padding="0"
                                Margin="16,0">

                            <Grid ColumnDefinitions="80,*" RowDefinitions="Auto" ColumnSpacing="12">

                                <!-- Game Image -->
                                <Border Grid.Column="0"
                                        Stroke="#222222"
                                        StrokeThickness="1"
                                        StrokeShape="RoundRectangle 8"
                                        WidthRequest="80"
                                        HeightRequest="80"
                                        BackgroundColor="#0D0D0D">
                                    <Image Source="{Binding Image}"
                                           Aspect="AspectFill"
                                           WidthRequest="80"
                                           HeightRequest="80" />
                                </Border>

                                <!-- Game Info -->
                                <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="4" Padding="0,4">

                                    <Label Text="{Binding Title}"
                                           FontSize="14"
                                           FontAttributes="Bold"
                                           TextColor="#FFFFFF"
                                           LineBreakMode="TailTruncation"
                                           MaxLines="2" />

                                    <Label Text="{Binding CurrentAchievements, StringFormat='{}{0} Achievements'}"
                                           FontSize="11"
                                           TextColor="#888888" />

                                    <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto" HeightRequest="6">

                                        <ProgressBar Grid.Column="0"
                                                     Progress="{Binding Progress}"
                                                     ProgressColor="#CC0000"
                                                     BackgroundColor="#1A1A1A"
                                                     VerticalOptions="Center"
                                                     HeightRequest="6" />

                                        <Label Grid.Column="1"
                                               Text="{Binding Gamerscore, StringFormat='{}{0}G'}"
                                               FontSize="10"
                                               FontAttributes="Bold"
                                               TextColor="#CC0000"
                                               VerticalOptions="Center"
                                               Margin="8,0,0,0" />
                                    </Grid>
                                </VerticalStackLayout>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </RefreshView>

    </Grid>

</ContentPage>
