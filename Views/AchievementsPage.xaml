<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:KrakenMobile.ViewModels"
             x:Class="KrakenMobile.Views.AchievementsPage"
             BackgroundColor="{DynamicResource KrakenBackground}"
             Title="Achievements">

    <Grid RowDefinitions="Auto,Auto,Auto,*">

        <!-- Game Header Card -->
        <Border Grid.Row="0"
                BackgroundColor="{DynamicResource KrakenStatBg}"
                Stroke="{DynamicResource KrakenStatBorder}"
                StrokeThickness="1"
                StrokeShape="RoundRectangle 10"
                Padding="16"
                Margin="16,12,16,0">

            <Grid ColumnDefinitions="60,*" ColumnSpacing="12">

                <!-- Game Box Art -->
                <Border Grid.Column="0"
                        Stroke="{DynamicResource KrakenStatBorder}"
                        StrokeThickness="1"
                        StrokeShape="RoundRectangle 8"
                        WidthRequest="60"
                        HeightRequest="60"
                        BackgroundColor="{DynamicResource KrakenCardDark}"
                         ><!-- ClipToBounds removed -->
                    <Image Source="{Binding GameImage}"
                           Aspect="AspectFill"
                           WidthRequest="60"
                           HeightRequest="60" />
                </Border>

                <!-- Game Info -->
                <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                    <Label Text="{Binding GameName}"
                           FontSize="16"
                           FontAttributes="Bold"
                           TextColor="{DynamicResource KrakenTextPrimary}"
                           LineBreakMode="TailTruncation" />
                    <Label Text="{Binding GameInfo}"
                           FontSize="12"
                           TextColor="{DynamicResource KrakenTextSecondary}" />
                </VerticalStackLayout>
            </Grid>
        </Border>

        <!-- Event Token Notice -->
        <Border Grid.Row="1"
                BackgroundColor="#1A1400"
                Stroke="#4D3800"
                StrokeThickness="1"
                 StrokeShape="RoundRectangle 8"
                 Padding="12,10"
                 Margin="16,8,16,0"
                 IsVisible="{Binding IsEventBased}">

            <VerticalStackLayout Spacing="2">
                <Label Text="EVENT-BASED ACHIEVEMENTS"
                       FontSize="10" FontAttributes="Bold"
                       TextColor="#CC8800" />
                <Label Text="Event-based achievements require an event token. Use the PC version of Kraken Unlocker to generate event tokens."
                       FontSize="11" TextColor="#998844"
                       LineBreakMode="WordWrap" />
            </VerticalStackLayout>
        </Border>

        <!-- Controls Bar -->
        <Border Grid.Row="2"
                BackgroundColor="{DynamicResource KrakenCard}"
                Stroke="{DynamicResource KrakenBorder}"
                StrokeThickness="0,0,0,1"
                Padding="16,10"
                Margin="16,8,16,0">

            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">

                <SearchBar Grid.Column="0"
                           Placeholder="Search achievements..."
                           PlaceholderColor="{DynamicResource KrakenTextTertiary}"
                           TextColor="{DynamicResource KrakenTextPrimary}"
                           BackgroundColor="{DynamicResource KrakenCardDark}"
                           FontSize="14"
                           CancelButtonColor="{DynamicResource KrakenTextSecondary}"
                           Text="{Binding SearchText}" />

                <Button Grid.Column="1"
                        Text="Unlock All"
                        Style="{StaticResource KrakenPrimaryButton}"
                        FontSize="13"
                        CornerRadius="8"
                        Padding="14,10"
                        IsEnabled="{Binding IsUnlockAllEnabled}"
                        Command="{Binding UnlockAllCommand}"
                        VerticalOptions="Center" />
            </Grid>
        </Border>

        <!-- Achievements List -->
        <RefreshView Grid.Row="3"
                     IsRefreshing="{Binding IsLoading}"
                     Command="{Binding LoadAchievementsCommand}"
                     RefreshColor="#CC0000">

            <CollectionView ItemsSource="{Binding Achievements}"
                            SelectionMode="None">
                <CollectionView.ItemsLayout>
                    <LinearItemsLayout Orientation="Vertical" ItemSpacing="6" />
                </CollectionView.ItemsLayout>
                <CollectionView.Header>
                    <BoxView HeightRequest="8" Color="Transparent" />
                </CollectionView.Header>
                <CollectionView.EmptyViewTemplate>
                    <DataTemplate>
                        <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Padding="32" Spacing="12">
                            <Label Text="No achievements"
                                   FontSize="18"
                                   FontAttributes="Bold"
                                   TextColor="{DynamicResource KrakenTextPrimary}"
                                   HorizontalOptions="Center" />
                            <Label Text="Select a game from the Games tab first."
                                   FontSize="13"
                                   TextColor="{DynamicResource KrakenTextSecondary}"
                                   HorizontalOptions="Center"
                                   HorizontalTextAlignment="Center" />
                        </VerticalStackLayout>
                    </DataTemplate>
                </CollectionView.EmptyViewTemplate>
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border BackgroundColor="{DynamicResource KrakenCard}"
                                Stroke="{DynamicResource KrakenBorder}"
                                StrokeThickness="1"
                                StrokeShape="RoundRectangle 8"
                                Padding="14,12"
                                Margin="16,0">

                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">

                                <!-- Achievement Info -->
                                <VerticalStackLayout Grid.Column="0" Spacing="3">

                                    <Label Text="{Binding Name}"
                                           FontSize="14"
                                           FontAttributes="Bold"
                                           TextColor="{DynamicResource KrakenTextPrimary}"
                                           LineBreakMode="TailTruncation"
                                           MaxLines="1" />

                                    <Label Text="{Binding Description}"
                                           FontSize="12"
                                           TextColor="{DynamicResource KrakenTextSecondary}"
                                           LineBreakMode="TailTruncation"
                                           MaxLines="2" />

                                    <Grid ColumnDefinitions="Auto,Auto,Auto" ColumnSpacing="8">
                                        <Label Grid.Column="0"
                                               Text="{Binding Gamerscore, StringFormat='{}{0}G'}"
                                               FontSize="11"
                                               FontAttributes="Bold"
                                               TextColor="#CC0000" />

                                        <Label Grid.Column="1"
                                               Text="{Binding ProgressState}"
                                               FontSize="11"
                                               TextColor="{Binding ProgressState, Converter={StaticResource AchievementStateColorConverter}}" />

                                        <Label Grid.Column="2"
                                               Text="{Binding RarityCategory}"
                                               FontSize="11"
                                               TextColor="{DynamicResource KrakenTextSecondary}"
                                               IsVisible="{Binding IsSecret, Converter={StaticResource InvertBoolConverter}}" />
                                    </Grid>
                                </VerticalStackLayout>

                                <!-- Unlock Button -->
                                <Button Grid.Column="1"
                                        Text="{Binding IsUnlockable, Converter={StaticResource UnlockButtonConverter}}"
                                        BackgroundColor="{Binding ProgressState, Converter={StaticResource UnlockBgConverter}}"
                                        TextColor="{DynamicResource KrakenTextPrimary}"
                                        FontSize="18"
                                        CornerRadius="8"
                                        WidthRequest="48"
                                        HeightRequest="48"
                                        Padding="0"
                                        IsEnabled="{Binding IsUnlockable}"
                                        VerticalOptions="Center"
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.UnlockAchievementCommand}"
                                        CommandParameter="{Binding .}" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </RefreshView>

    </Grid>

</ContentPage>
