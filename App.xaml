<?xml version = "1.0" encoding = "UTF-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:KrakenMobile.Views"
             x:Class="KrakenMobile.App">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Styles/Colors.xaml" />
                <ResourceDictionary Source="Resources/Styles/Styles.xaml" />
                <ResourceDictionary Source="Resources/Styles/Themes/DarkTheme.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <local:AchievementStateColorConverter x:Key="AchievementStateColorConverter" />
            <local:UnlockButtonConverter x:Key="UnlockButtonConverter" />
            <local:UnlockBgConverter x:Key="UnlockBgConverter" />
            <local:InvertBoolConverter x:Key="InvertBoolConverter" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
